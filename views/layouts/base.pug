doctype html
html(lang="ko")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover")
    title #{title} | 파티 게임즈
    script.
      try {
        var t = localStorage.getItem('pg-theme'); if (t && t !== 'green') document.documentElement.dataset.theme = t;
        var o = parseInt(localStorage.getItem('pg-opacity'), 10);
        if (Number.isFinite(o) && o >= 30 && o < 100) document.documentElement.style.opacity = o / 100;
      } catch (e) {}
    link(rel="stylesheet" href=`/css/${cssFile}.css`)
  body
    block overlays
      if hasFlash
        #flash-overlay

      #error-toast
      #join-toast

    block content

    include ../mixins/chat

    block scripts
      script(type="module" src=`/js/${jsFile}.js`)
      script(type="module" src="/js/online-widget.js")
      script(type="module" src="/js/shared/themeManager.js")
