mixin lobby(opts)
  #screen-lobby.screen.active
    .card.fade-in
      div(style="text-align:center;margin-bottom:8px;")
        if opts.logoImg
          img(src=opts.logoImg alt=opts.title style="width:192px;height:auto;")
        else
          div(style="font-size:5rem;line-height:1;")= opts.logoEmoji

      h1(class=opts.titleClass || 'title-croc')= opts.title
      p.title-sub= opts.subtitle

      #user-info-bar(style="display:none;align-items:center;gap:8px;background:#0d2b1a;border:1px solid #1e4d2e;border-radius:10px;padding:9px 14px;margin-bottom:14px;")
        span#session-avatar(style="font-size:1.4rem;width:40px;height:40px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-shrink:0;") 😊
        span#session-nick(style="font-weight:700;color:var(--green-light);flex:1;font-size:0.95rem;")
          span#session-nick-name
        a(href="/" style="font-size:0.73rem;color:#456355;text-decoration:none;border:1px solid #1e4d2e;border-radius:20px;padding:3px 10px;") ← 홈

      #name-input-wrap
        label(for="player-name") 내 닉네임
        input#player-name(type="text" placeholder="닉네임 입력 (최대 16자)" maxlength="16")

      button#btn-create.btn.btn-primary 방 만들기

      block

      .divider 참여 가능한 방

      #room-list
        p.no-rooms-hint 현재 생성된 방이 없습니다
