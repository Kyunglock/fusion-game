extends ../layouts/base
include ../mixins/lobby
include ../mixins/waiting
include ../mixins/overlays

block overlays
  #error-toast
  #join-toast

block content
  +lobby({ logoEmoji: '🔤', title: '자모 워들', titleClass: 'title-jamo', subtitle: '숨겨진 낱말을 자모로 맞혀보세요! 🔡' })

  +waitingRoom({ subtext: '방장은 게임에 입장한 뒤 제시어를 내고, 참가자들이 자모로 맞힙니다' })
    #jamo-host-setup(style="display:none")
      label.toggle-row
        input#input-keyboard-toggle(type="checkbox" checked)
        span 참가자 키보드 보이기

  #screen-game.screen
    +spectatorGame

    #jamo-banner
    #jamo-scoreboard

    //- 방장 제시어 출제 (라운드 사이에만 노출)
    #jamo-host-round(style="display:none")
      input#input-answer(type="text" placeholder="제시어 입력 (예: 자연, 월드컵)" maxlength="20" autocomplete="off")
      button#btn-set-answer.btn.btn-primary 제시어 내기

    //- 참가자 라운드 대기 안내
    #jamo-wait-notice(style="display:none")

    #jamo-boards

    //- 내 키보드 (보드 카드 밖, 참가자 전용)
    #jamo-my-keyboard(style="display:none")

    #jamo-guess-row
      input#input-guess(type="text" placeholder="답 입력" maxlength="20" autocomplete="off")
      button#btn-submit-guess.btn.btn-primary 제출

  +aloneOverlay('🔤💨')
